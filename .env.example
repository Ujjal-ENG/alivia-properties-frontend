NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Marketplace destination. Leave empty/unset → header pill links to /marketplace
# (same-origin route inside this app). Set this to a full https://... URL ONLY
# after you have configured the subdomain on Vercel:
#   Project → Settings → Domains → Add `market-place.<your-domain>`
# Vercel does NOT auto-create wildcard subdomains on free *.vercel.app deployments,
# so the placeholder hostname won't resolve until you add it.
NEXT_PUBLIC_MARKETPLACE_URL=

# Auth.js — generate with: npx auth secret
AUTH_SECRET=
