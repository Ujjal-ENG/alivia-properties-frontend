# Keep build context tiny — faster `docker build`, smaller cache invalidations.

# Dependencies (re-installed inside the image)
node_modules
.pnpm-store

# Build outputs
.next
out
build
dist

# Git & CI
.git
.gitignore
.gitattributes
.github

# Local env files — never bake secrets into the image.
# .env.example is allowed through for reference.
.env
.env.*
!.env.example

# IDE / editor / OS
.vscode
.idea
.DS_Store
*.swp
*.swo
Thumbs.db

# Logs & debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# Tests & coverage
coverage
.nyc_output
**/__tests__
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx

# Docs & meta — not needed at runtime
README.md
AGENTS.md
CLAUDE.md
USER.md
*.md
LICENSE
files_to_commit.txt

# Tooling configs not needed at runtime
.claude
.codex
.agents
skills-lock.json

# Vercel
.vercel

# TypeScript incremental cache
*.tsbuildinfo
next-env.d.ts

# Docker (don't recursively copy)
Dockerfile*
.dockerignore
docker-compose*.yml
